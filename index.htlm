/* ==============================
GLOBAL RESET
============================== */

* {
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Inter',sans-serif;
    scroll-behavior:smooth;
}


body {

    background:#07070b;
    color:white;
    overflow-x:hidden;

}


a {

    color:white;
    text-decoration:none;

}


button {

    border:none;
    cursor:pointer;
    transition:.3s;

}



/* ==============================
LOADING SCREEN
============================== */


#loadingScreen {

    position:fixed;
    inset:0;
    background:#07070b;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    z-index:9999;

}


.loader {

    width:60px;
    height:60px;
    border-radius:50%;
    border:6px solid #222;
    border-top-color:#8b5cf6;
    animation:spin 1s linear infinite;
    margin-bottom:20px;

}


@keyframes spin {

    to {
        transform:rotate(360deg);
    }

}




/* ==============================
NAVBAR
============================== */


.navbar {

    position:sticky;
    top:0;
    z-index:1000;

    display:flex;
    justify-content:space-between;
    align-items:center;

    padding:20px 8%;

    background:rgba(7,7,11,.85);
    backdrop-filter:blur(20px);

    border-bottom:1px solid rgba(255,255,255,.05);

}



.logo {

    display:flex;
    align-items:center;
    gap:12px;

    font-size:22px;
    font-weight:800;

}



.logo-icon {

    width:42px;
    height:42px;

    display:flex;
    align-items:center;
    justify-content:center;

    border-radius:12px;

    background:linear-gradient(
        135deg,
        #8b5cf6,
        #06b6d4
    );

}



.navbar nav {

    display:flex;
    gap:30px;

}


.navbar nav a {

    color:#aaa;
    transition:.3s;

}


.navbar nav a:hover {

    color:white;

}



.cart-button {

    background:#8b5cf6;
    color:white;

    padding:12px 20px;

    border-radius:12px;

}


.cart-button:hover {

    transform:translateY(-2px);

}





/* ==============================
HERO
============================== */


.hero {

    min-height:80vh;

    display:flex;
    align-items:center;
    justify-content:space-between;

    padding:80px 8%;

    background:

    radial-gradient(
        circle at top right,
        rgba(139,92,246,.3),
        transparent 40%
    );

}



.hero-content {

    max-width:600px;

}


.hero h1 {

    font-size:70px;
    line-height:1.1;

    font-weight:900;

}



.hero p {

    margin:25px 0;

    color:#aaa;

    font-size:20px;

}



.hero button {

    padding:16px 30px;

    border-radius:14px;

    background:#8b5cf6;

    color:white;

    font-size:16px;

}



.hero button:hover {

    transform:scale(1.05);

}





.hero-card {

    padding:40px;

    width:330px;

    border-radius:25px;

    background:
    rgba(255,255,255,.05);

    border:
    1px solid rgba(255,255,255,.1);

    backdrop-filter:blur(20px);

}


.hero-card i {

    font-size:45px;
    color:#8b5cf6;

}




/* ==============================
STATS
============================== */


.stats {

    display:grid;

    grid-template-columns:
    repeat(4,1fr);

    gap:20px;

    padding:50px 8%;

}



.stat-box {

    padding:30px;

    text-align:center;

    border-radius:20px;

    background:#11111a;

    border:1px solid rgba(255,255,255,.05);

}



.stat-box h2 {

    font-size:40px;
    color:#8b5cf6;

}




/* ==============================
PRODUCTS
============================== */


.products-section {

    padding:80px 8%;

}



.section-title {

    text-align:center;

    margin-bottom:40px;

}



.section-title h2 {

    font-size:45px;

}



.section-title p {

    color:#999;

}




.filters {

    display:flex;

    justify-content:center;

    gap:20px;

    margin-bottom:40px;

}



.filters input,
.filters select {

    padding:15px;

    background:#11111a;

    color:white;

    border-radius:12px;

    border:1px solid #222;

}





.product-grid {

    display:grid;

    grid-template-columns:
    repeat(3,1fr);

    gap:25px;

}



.product-card {

    padding:30px;

    background:#11111a;

    border-radius:25px;

    border:
    1px solid rgba(255,255,255,.05);

    transition:.35s;

}



.product-card:hover {

    transform:translateY(-10px);

    border-color:#8b5cf6;

}




.product-image {

    height:150px;

    display:flex;

    justify-content:center;

    align-items:center;

    background:#0b0b12;

    border-radius:20px;

    margin-bottom:20px;

}



.product-image i {

    font-size:55px;

    color:#8b5cf6;

}



.product-card h3 {

    font-size:22px;

    margin-bottom:10px;

}



.product-card p {

    color:#999;

    margin-bottom:15px;

}



.product-card h4 {

    font-size:25px;

    margin-bottom:20px;

}



.product-card button {

    width:100%;

    padding:14px;

    border-radius:12px;

    background:#8b5cf6;

    color:white;

}



.product-card button:hover {

    background:#7c3aed;

}



.quantity-control {

    display:flex;

    gap:10px;

    margin-bottom:15px;

}



.quantity-control button {

    width:40px;

}



.quantity-control input {

    width:60px;

    text-align:center;

    background:#08080c;

    color:white;

    border:none;

}





/* ==============================
MODAL CART
============================== */


.modal {

    display:none;

    position:fixed;

    inset:0;

    background:rgba(0,0,0,.7);

    align-items:center;

    justify-content:center;

    z-index:2000;

}



.modal-content {

    width:500px;

    max-width:90%;

    background:#11111a;

    padding:35px;

    border-radius:25px;

}



.close {

    float:right;

    background:none;

    color:white;

    font-size:20px;

}



/* ==============================
RESPONSIVE
============================== */


@media(max-width:900px){


.navbar nav {

    display:none;

}


.hero {

    flex-direction:column;

    text-align:center;

    gap:50px;

}


.hero h1 {

    font-size:45px;

}


.stats {

    grid-template-columns:
    repeat(2,1fr);

}


.product-grid {

    grid-template-columns:1fr;

}


}




@media(max-width:500px){


.stats {

    grid-template-columns:1fr;

}


.cart-button {

    padding:10px;

}



}
/* ==============================
SHOP SELL AUTH
MAIN JAVASCRIPT
============================== */


// ==============================
// PRODUCT DATABASE
// ==============================

const products = {

discordDecoration:{
    name:"Discord Decoration",
    price:1.20
},

discordNitro:{
    name:"Discord Nitro",
    price:2.99
},

boost1:{
    name:"14x Server Boost (1 Month)",
    price:3
},

boost3:{
    name:"14x Server Boost (3 Months)",
    price:5.99
},

members1000:{
    name:"1000 Real Members",
    price:2
},

members10000:{
    name:"10000 Real Members",
    price:15
}

};



let cart = JSON.parse(localStorage.getItem("cart")) || [];



// ==============================
// LOADING SCREEN
// ==============================

window.onload = () => {

    setTimeout(()=>{

        document.getElementById("loadingScreen").style.display="none";

    },1500);


    updateCart();

};




// ==============================
// QUANTITY CONTROLLER
// ==============================


function changeQuantity(id,value){

    let input=document.getElementById(id+"Qty");

    let amount=parseInt(input.value);

    amount+=value;

    if(amount<1)
        amount=1;


    input.value=amount;

}




// ==============================
// ROBUX CALCULATOR
// ==============================


function calculateRobux(){

    let amount=
    Number(document.getElementById("robuxAmount").value);


    if(amount<0)
        amount=0;


    let price=(amount/1000)*3;


    document.getElementById("robuxPrice")
    .innerText="$"+price.toFixed(2);

}




function addRobuxToCart(){


    let amount=
    Number(document.getElementById("robuxAmount").value);


    let price=(amount/1000)*3;


    cart.push({

        name:
        amount+" Robux",

        price:price,

        quantity:1

    });


    saveCart();

    toast("Robux added to cart");


}




// ==============================
// ADD TO CART
// ==============================


function addToCart(id){


    let quantity=1;


    if(document.getElementById(id+"Qty")){

        quantity=
        Number(
        document.getElementById(id+"Qty").value
        );

    }



    let product=products[id];


    cart.push({

        name:product.name,

        price:product.price,

        quantity:quantity

    });


    saveCart();


    toast(
    product.name+" added"
    );


}




function saveCart(){

    localStorage.setItem(
        "cart",
        JSON.stringify(cart)
    );


    updateCart();

}




// ==============================
// CART SYSTEM
// ==============================


function updateCart(){


    let count=0;


    cart.forEach(item=>{

        count+=item.quantity;

    });



    document.getElementById("cartCount")
    .innerText=count;



    let total=0;


    cart.forEach(item=>{

        total+=item.price*item.quantity;

    });


    document.getElementById("cartTotal")
    .innerText="$"+total.toFixed(2);



    let box=
    document.getElementById("cartItems");


    box.innerHTML="";



    if(cart.length===0){

        box.innerHTML=
        "<p>Your cart is empty</p>";

        return;

    }



    cart.forEach((item,index)=>{


        box.innerHTML+=`

        <div style="
        padding:15px;
        border-bottom:1px solid #333">

        <b>${item.name}</b>

        <br>

        $${item.price.toFixed(2)}

        x ${item.quantity}

        <br>

        <button onclick="removeCart(${index})">
        Remove
        </button>

        </div>

        `;


    });


}




function removeCart(index){

    cart.splice(index,1);

    saveCart();

}




function openCart(){

    document.getElementById("cartModal")
    .style.display="flex";

}



function closeCart(){

    document.getElementById("cartModal")
    .style.display="none";

}





// ==============================
// CHECKOUT
// ==============================


function checkout(){


    if(cart.length===0){

        toast("Cart is empty");

        return;

    }


    closeCart();



    let total=0;


    cart.forEach(item=>{

        total+=item.price*item.quantity;

    });



    let order={


        id:
        "SSA-"+Date.now(),


        products:cart,


        total:
        total.toFixed(2),


        payment:
        "Litecoin",


        timestamp:
        new Date().toLocaleString()


    };



    localStorage.setItem(
        "currentOrder",
        JSON.stringify(order)
    );



    showPayment(order);


}




// ==============================
// PAYMENT SCREEN
// ==============================


function showPayment(order){


    let payment=`

<div class="modal" style="display:flex">

<div class="modal-content">


<h2>
Litecoin Payment
</h2>


<p>
Send exactly:
</p>


<h1>
$${order.total}
</h1>


<p>
LTC Address:
</p>


<input value="
LXZaCfP5tt9yyScUB59ckTMrmrUUEg995p
"
readonly
style="width:100%;padding:12px">


<button onclick="copyWallet()">
Copy Address
</button>



<br><br>


<p>
Send the exact amount shown above.
</p>


<button onclick="paidForm()">

I Have Paid

</button>


</div>

</div>

`;


document.body.insertAdjacentHTML(
"beforeend",
payment
);


}




function copyWallet(){

navigator.clipboard.writeText(
"LXZaCfP5tt9yyScUB59ckTMrmrUUEg995p"
);


toast("Address copied");


}




// ==============================
// TXID FORM
// ==============================


function paidForm(){


let box=document.createElement("div");


box.className="modal";

box.style.display="flex";


box.innerHTML=`

<div class="modal-content">


<h2>
Payment Verification
</h2>


<input id="txid"
placeholder="TXID"
style="width:100%;padding:15px">


<br><br>


<input id="email"
placeholder="Email (optional)"
style="width:100%;padding:15px">


<br><br>


<button onclick="verifyPayment()">

Verify Payment

</button>


</div>

`;


document.body.appendChild(box);


}





// ==============================
// VERIFICATION ANIMATION
// ==============================


function verifyPayment(){


let steps=[

"Connecting to Litecoin Network...",
"Searching Transaction...",
"Verifying Payment Amount...",
"Checking Blockchain Confirmations...",
"Finalizing Verification..."

];



let popup=document.querySelector(".modal:last-child");



popup.querySelector(".modal-content")
.innerHTML=`

<h2>
Checking Payment
</h2>

<h3 id="verifyText"></h3>

<div style="
height:10px;
background:#222;
border-radius:10px">

<div id="bar"
style="
height:100%;
width:0%;
background:#8b5cf6;
border-radius:10px">

</div>

</div>

`;



let i=0;


let interval=setInterval(()=>{


document.getElementById("verifyText")
.innerText=steps[i];


document.getElementById("bar")
.style.width=((i+1)*20)+"%";



i++;



if(i===steps.length){


clearInterval(interval);



setTimeout(()=>{


popup.querySelector(".modal-content")
.innerHTML=`

<h2>
Verification Error
</h2>


<p>

An unexpected system error occurred while processing your order.

</p>


<p>

Please contact support for manual order processing.

</p>


<a href="https://discord.gg/VC77BhU8rC"
target="_blank">


<button>

Join Discord Support

</button>


</a>


`;



},1000);


}


},1200);


}





// ==============================
// SEARCH
// ==============================


function searchProducts(){

let value=
document.getElementById("searchInput")
.value.toLowerCase();



document.querySelectorAll(".product-card")
.forEach(card=>{


if(card.innerText.toLowerCase()
.includes(value))

card.style.display="block";


else

card.style.display="none";


});


}





// ==============================
// SORT PLACEHOLDER
// ==============================


function sortProducts(){

toast("Sorting enabled");

}





// ==============================
// SCROLL
// ==============================


function scrollProducts(){

document.getElementById("products")
.scrollIntoView();

}





// ==============================
// TOAST NOTIFICATIONS
// ==============================


function toast(message){


let t=document.createElement("div");


t.innerText=message;


t.style.position="fixed";

t.style.bottom="30px";

t.style.right="30px";

t.style.background="#8b5cf6";

t.style.padding="15px 25px";

t.style.borderRadius="12px";

t.style.zIndex="9999";


document.body.appendChild(t);



setTimeout(()=>{

t.remove();

},2500);


}
